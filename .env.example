# SRE Tea MCP Server Configuration
# Copy this file to .env and fill in your values

# ============================================================
# AUTHENTICATION (Required - choose one method)
# ============================================================

# Method 1: Pre-authenticated token (recommended for production)
# SRE_ADMIN_TOKEN=your-bearer-token-here

# Method 2: Email + Password authentication (for development)
SRE_ADMIN_EMAIL=admin@sre.local
SRE_ADMIN_PASSWORD=your-password-here

# ============================================================
# API CONFIGURATION (Optional)
# ============================================================

# API Base URL (default: production endpoint)
# SRE_API_URL=https://jzwp96mgv2.execute-api.ap-south-1.amazonaws.com/prod/api/v1

# ============================================================
# LOGGING (Optional)
# ============================================================

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
